# Copy to fabric-hosts.def and edit. Regenerated into docker-compose.hosts.yml on every `make up`.
#
# Columns (space-separated):
#   HOST_KEY  MSP_ID  CRYPTO_PEER_DIR  GATEWAY_PEER  HOST_PEER_PORT  API_PORT  WEB_PORT
#
# HOST_KEY          — service suffix (api-<KEY>, web-<KEY>); use letters/digits/dots/hyphens
# CRYPTO_PEER_DIR   — directory under fabric-samples/.../peerOrganizations/ (e.g. org1.example.com)
# GATEWAY_PEER      — peer DNS name Fabric expects (e.g. peer0.org1.example.com)
# HOST_PEER_PORT    — gRPC port on the host (7051 Org1, 9051 Org2, 11051 Org3 on test-network)
#
# Enrolled user is always User1@${CRYPTO_PEER_DIR} (test-network default).

org1 Org1MSP org1.example.com peer0.org1.example.com 7051 8080 8081
org2 Org2MSP org2.example.com peer0.org2.example.com 9051 8090 8091
# org3 Org3MSP org3.example.com peer0.org3.example.com 11051 8092 8093
